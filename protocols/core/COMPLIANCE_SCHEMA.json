{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ZKputer Trade Compliance Schema",
  "description": "Schema for trade records ensuring full auditability",
  "type": "object",
  "required": [
    "trade_id",
    "timestamp",
    "ops_mode",
    "symbol",
    "side",
    "entry_price",
    "size",
    "stop_loss",
    "risk_usd",
    "thesis",
    "sources",
    "compliance_checks",
    "approval"
  ],
  "properties": {
    "trade_id": {
      "type": "string",
      "description": "Unique trade identifier (UUID or exchange order ID)"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 timestamp of trade creation"
    },
    "ops_mode": {
      "type": "string",
      "enum": ["BaseOPS", "ExtendOPS", "HyperOPS", "PumpOPS"],
      "description": "Active OPS mode at time of trade"
    },
    "symbol": {
      "type": "string",
      "description": "Trading pair (e.g., SOL-USD, BTC-PERP, $TOKEN)"
    },
    "side": {
      "type": "string",
      "enum": ["BUY", "SELL", "LONG", "SHORT"],
      "description": "Trade direction"
    },
    "entry_price": {
      "type": "number",
      "minimum": 0,
      "description": "Entry price in quote currency"
    },
    "size": {
      "type": "number",
      "minimum": 0,
      "description": "Position size in base currency"
    },
    "notional_usd": {
      "type": "number",
      "minimum": 0,
      "description": "Total position value in USD"
    },
    "leverage": {
      "type": "number",
      "minimum": 1,
      "maximum": 12,
      "description": "Leverage used (1 for spot)"
    },
    "stop_loss": {
      "type": "object",
      "required": ["price", "order_type"],
      "properties": {
        "price": {
          "type": "number",
          "description": "Stop loss trigger price"
        },
        "order_type": {
          "type": "string",
          "enum": ["STOP", "STOP_LIMIT", "STOP_MARKET"],
          "description": "Order type for stop loss"
        },
        "distance_percent": {
          "type": "number",
          "description": "Distance from entry as percentage"
        }
      }
    },
    "take_profit": {
      "type": "object",
      "properties": {
        "tp1": {
          "type": "object",
          "properties": {
            "price": { "type": "number" },
            "size_percent": { "type": "number" }
          }
        },
        "tp2": {
          "type": "object",
          "properties": {
            "price": { "type": "number" },
            "size_percent": { "type": "number" }
          }
        }
      }
    },
    "risk_usd": {
      "type": "number",
      "minimum": 0,
      "description": "Maximum risk in USD if stop hit"
    },
    "risk_percent": {
      "type": "number",
      "minimum": 0,
      "maximum": 20,
      "description": "Risk as percentage of account equity"
    },
    "expected_rr": {
      "type": "number",
      "minimum": 0,
      "description": "Expected risk:reward ratio"
    },
    "thesis": {
      "type": "string",
      "minLength": 10,
      "description": "Trading thesis and catalyst"
    },
    "setup_type": {
      "type": "string",
      "enum": [
        "FUNDING_ARB",
        "MOMENTUM_CATALYST",
        "LIQUIDITY_HUNT",
        "MEAN_REVERSION",
        "SMART_MONEY_FOLLOW",
        "TECHNICAL_BREAKOUT",
        "NEWS_CATALYST",
        "GEM_DISCOVERY",
        "SNIPE"
      ],
      "description": "Type of trading setup"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["API", "BROWSER", "KNOWLEDGE_GRAPH", "SOCIAL", "ON_CHAIN"]
          },
          "url": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "minItems": 1,
      "description": "Data sources used to form thesis"
    },
    "compliance_checks": {
      "type": "object",
      "required": ["risk_limit", "leverage_limit", "stop_loss_valid"],
      "properties": {
        "risk_limit": {
          "type": "object",
          "properties": {
            "passed": { "type": "boolean" },
            "value": { "type": "number" },
            "limit": { "type": "number" }
          }
        },
        "leverage_limit": {
          "type": "object",
          "properties": {
            "passed": { "type": "boolean" },
            "value": { "type": "number" },
            "limit": { "type": "number" }
          }
        },
        "stop_loss_valid": {
          "type": "object",
          "properties": {
            "passed": { "type": "boolean" },
            "order_type": { "type": "string" }
          }
        },
        "multi_source_verified": {
          "type": "object",
          "properties": {
            "passed": { "type": "boolean" },
            "source_count": { "type": "integer" },
            "required": { "type": "integer" }
          }
        },
        "ops_specific": {
          "type": "object",
          "description": "OPS-mode specific compliance checks"
        }
      }
    },
    "approval": {
      "type": "object",
      "required": ["approved", "approved_by", "timestamp"],
      "properties": {
        "approved": { "type": "boolean" },
        "approved_by": {
          "type": "string",
          "enum": ["USER", "OVERRIDE"],
          "description": "Who approved the trade"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "command": {
          "type": "string",
          "description": "Exact user command that approved the trade"
        }
      }
    },
    "execution": {
      "type": "object",
      "description": "Populated after trade execution",
      "properties": {
        "exchange_order_id": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["PENDING", "FILLED", "PARTIAL", "CANCELLED", "FAILED"]
        },
        "fill_price": { "type": "number" },
        "fill_size": { "type": "number" },
        "fill_timestamp": { "type": "string", "format": "date-time" },
        "fees_usd": { "type": "number" },
        "slippage_percent": { "type": "number" }
      }
    },
    "outcome": {
      "type": "object",
      "description": "Populated after trade closes",
      "properties": {
        "exit_price": { "type": "number" },
        "exit_timestamp": { "type": "string", "format": "date-time" },
        "exit_reason": {
          "type": "string",
          "enum": ["TP1", "TP2", "STOP_LOSS", "MANUAL", "MAE_CUT", "TRAILING_STOP"]
        },
        "pnl_usd": { "type": "number" },
        "pnl_percent": { "type": "number" },
        "r_multiple": { "type": "number" },
        "duration_minutes": { "type": "number" },
        "notes": { "type": "string" }
      }
    }
  }
}
